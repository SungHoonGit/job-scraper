# ──────────────────────────────────────
# Job Scraper — Secret environment vars
# Copy this file to .env and fill values
# ──────────────────────────────────────

# Email (SMTP TLS) — Gmail 권장
# Gmail 앱 비밀번호 필요: https://myaccount.google.com/apppasswords
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient@example.com,backup@example.com

# KakaoTalk — Kakao Developers REST API
# Guide: https://developers.kakao.com/docs/latest/ko/message/rest-api
KAKAO_REST_API_KEY=your-rest-api-key
KAKAO_ACCESS_TOKEN=your-access-token

# Telegram Bot
# BotFather에서 봇 생성: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
